{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.45.15.27210",
      "templateHash": "8528104234938541886"
    }
  },
  "parameters": {
    "namePrefix": {
      "type": "string"
    },
    "env": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "caeId": {
      "type": "string"
    },
    "acrLoginServer": {
      "type": "string"
    },
    "keyVaultName": {
      "type": "string"
    },
    "ingressPublic": {
      "type": "bool"
    },
    "appId": {
      "type": "string"
    },
    "tenantId": {
      "type": "string"
    },
    "caeDefaultDomain": {
      "type": "string"
    },
    "imageTag": {
      "type": "string",
      "defaultValue": "latest"
    }
  },
  "resources": [
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[format('{0}-{1}-prod2', parameters('namePrefix'), parameters('env'))]",
      "location": "[parameters('location')]",
      "tags": {
        "project": "INT101",
        "env": "[parameters('env')]",
        "owner": "DNAI",
        "managedBy": "bicep",
        "app": "prod2"
      },
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-{1}-ci', parameters('namePrefix'), parameters('env'))))]": {},
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-{1}-app-kv', parameters('namePrefix'), parameters('env'))))]": {}
        }
      },
      "properties": {
        "managedEnvironmentId": "[parameters('caeId')]",
        "configuration": {
          "ingress": {
            "external": "[parameters('ingressPublic')]",
            "targetPort": 8000,
            "transport": "auto"
          },
          "registries": [
            {
              "server": "[parameters('acrLoginServer')]",
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-{1}-ci', parameters('namePrefix'), parameters('env')))]"
            }
          ],
          "secrets": [
            {
              "name": "database-url",
              "keyVaultUrl": "[format('https://{0}.vault.azure.net/secrets/prod2-database-url', parameters('keyVaultName'))]",
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-{1}-app-kv', parameters('namePrefix'), parameters('env')))]"
            },
            {
              "name": "session-secret",
              "keyVaultUrl": "[format('https://{0}.vault.azure.net/secrets/prod2-session-secret', parameters('keyVaultName'))]",
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-{1}-app-kv', parameters('namePrefix'), parameters('env')))]"
            },
            {
              "name": "oidc-secret",
              "keyVaultUrl": "[format('https://{0}.vault.azure.net/secrets/prod2-oidc-client-secret', parameters('keyVaultName'))]",
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-{1}-app-kv', parameters('namePrefix'), parameters('env')))]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "prod2-warning",
              "image": "[format('{0}/prod2-warning:{1}', parameters('acrLoginServer'), parameters('imageTag'))]",
              "resources": {
                "cpu": "[json('0.5')]",
                "memory": "1Gi"
              },
              "env": [
                {
                  "name": "DATABASE_URL",
                  "secretRef": "database-url"
                },
                {
                  "name": "SESSION_SECRET_KEY",
                  "secretRef": "session-secret"
                },
                {
                  "name": "OIDC_CLIENT_SECRET",
                  "secretRef": "oidc-secret"
                },
                {
                  "name": "OIDC_CLIENT_ID",
                  "value": "[parameters('appId')]"
                },
                {
                  "name": "OIDC_ISSUER",
                  "value": "[format('https://login.microsoftonline.com/{0}/v2.0', parameters('tenantId'))]"
                },
                {
                  "name": "APP_PUBLIC_URL",
                  "value": "[format('https://{0}-{1}-prod2.{2}', parameters('namePrefix'), parameters('env'), parameters('caeDefaultDomain'))]"
                },
                {
                  "name": "OIDC_SCOPES",
                  "value": "openid profile email"
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": 1,
            "maxReplicas": 3
          }
        }
      }
    }
  ],
  "outputs": {
    "appFqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/containerApps', format('{0}-{1}-prod2', parameters('namePrefix'), parameters('env'))), '2024-03-01').configuration.ingress.fqdn]"
    }
  }
}